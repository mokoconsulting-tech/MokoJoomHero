<?xml version="1.0" encoding="UTF-8"?>
<extension type="module" client="site" method="upgrade">
    <name>MOD_MOKO_HERO</name>
    <author>Moko Consulting</author>
    <authorEmail>hello@mokoconsulting.tech</authorEmail>
    <authorUrl>https://mokoconsulting.tech</authorUrl>
    <creationDate>2026-03</creationDate>
    <copyright>Copyright (C) 2026 Moko Consulting. All rights reserved.</copyright>
    <license>GNU General Public License version 3 or later</license>
    <version>1.0.0</version>
    <description>MOD_MOKO_HERO_XML_DESCRIPTION</description>

    <!--
        namespace path points at src/ which is now the module root itself.
        Joomla resolves namespaces relative to the extension root, so
        src/Helper/MokoHeroHelper.php → MokoConsulting\Module\MokoHero\Site\Helper\MokoHeroHelper
    -->
    <namespace path="src">MokoConsulting\Module\MokoHero</namespace>

    <files>
        <filename module="mod_moko_hero">mod_moko_hero.php</filename>
        <folder>Site</folder>
        <folder>tmpl</folder>
        <folder>media</folder>
    </files>

    <languages folder="language">
        <language tag="en-GB">en-GB/mod_moko_hero.ini</language>
        <language tag="en-GB">en-GB/mod_moko_hero.sys.ini</language>
    </languages>

    <media destination="mod_moko_hero" folder="media">
        <folder>css</folder>
    </media>

    <config>
        <fields name="params">

            <fieldset name="basic" label="JGLOBAL_FIELDSET_DISPLAY_OPTIONS">

                <!--
                    folder field — uses Joomla's built-in "folderlist" field type.
                    Renders a drop-down of all immediate subdirectories under the
                    path specified in `directory` (relative to JPATH_SITE).
                    Mirrors the approach used by mod_random_image.

                    If you store hero images directly under images/ itself, change
                    `directory` to "" and set `default` to "images".
                -->
                <field
                    name="folder"
                    type="folderlist"
                    label="MOD_MOKO_HERO_FIELD_FOLDER_LABEL"
                    description="MOD_MOKO_HERO_FIELD_FOLDER_DESC"
                    directory="images"
                    default="headers"
                    filter=""
                    exclude="^\..*"
                    hide_none="false"
                    hide_default="false"
                    required="true"
                />

                <!-- ── Text levels (WYSIWYG) ───────────────────────────── -->

                <field
                    name="text1"
                    type="editor"
                    label="MOD_MOKO_HERO_FIELD_TEXT1_LABEL"
                    description="MOD_MOKO_HERO_FIELD_TEXT1_DESC"
                    default=""
                    filter="raw"
                    buttons="true"
                    hide="pagebreak,readmore"
                />

                <field
                    name="text2"
                    type="editor"
                    label="MOD_MOKO_HERO_FIELD_TEXT2_LABEL"
                    description="MOD_MOKO_HERO_FIELD_TEXT2_DESC"
                    default=""
                    filter="raw"
                    buttons="true"
                    hide="pagebreak,readmore"
                />

                <field
                    name="text3"
                    type="editor"
                    label="MOD_MOKO_HERO_FIELD_TEXT3_LABEL"
                    description="MOD_MOKO_HERO_FIELD_TEXT3_DESC"
                    default=""
                    filter="raw"
                    buttons="true"
                    hide="pagebreak,readmore"
                />

                <!-- ── Button 1 ────────────────────────────────────────── -->

                <field
                    name="btn1_label"
                    type="text"
                    label="MOD_MOKO_HERO_FIELD_BTN1_LABEL_LABEL"
                    description="MOD_MOKO_HERO_FIELD_BTN_LABEL_DESC"
                    default=""
                />

                <field
                    name="btn1_icon"
                    type="text"
                    label="MOD_MOKO_HERO_FIELD_BTN_ICON_LABEL"
                    description="MOD_MOKO_HERO_FIELD_BTN_ICON_DESC"
                    default=""
                    hint="MOD_MOKO_HERO_FIELD_BTN_ICON_HINT"
                />

                <field
                    name="btn1_url"
                    type="url"
                    label="MOD_MOKO_HERO_FIELD_BTN1_URL_LABEL"
                    description="MOD_MOKO_HERO_FIELD_BTN_URL_DESC"
                    default=""
                    filter="url"
                />

                <field
                    name="btn1_style"
                    type="list"
                    label="MOD_MOKO_HERO_FIELD_BTN_STYLE_LABEL"
                    description="MOD_MOKO_HERO_FIELD_BTN_STYLE_DESC"
                    default="btn-primary"
                >
                    <option value="btn-primary">MOD_MOKO_HERO_BTN_STYLE_PRIMARY</option>
                    <option value="btn-secondary">MOD_MOKO_HERO_BTN_STYLE_SECONDARY</option>
                    <option value="btn-outline-primary">MOD_MOKO_HERO_BTN_STYLE_OUTLINE_PRIMARY</option>
                    <option value="btn-outline-light">MOD_MOKO_HERO_BTN_STYLE_OUTLINE_LIGHT</option>
                    <option value="btn-light">MOD_MOKO_HERO_BTN_STYLE_LIGHT</option>
                    <option value="btn-dark">MOD_MOKO_HERO_BTN_STYLE_DARK</option>
                </field>

                <!-- ── Button 2 ────────────────────────────────────────── -->

                <field
                    name="btn2_label"
                    type="text"
                    label="MOD_MOKO_HERO_FIELD_BTN2_LABEL_LABEL"
                    description="MOD_MOKO_HERO_FIELD_BTN_LABEL_DESC"
                    default=""
                />

                <field
                    name="btn2_icon"
                    type="text"
                    label="MOD_MOKO_HERO_FIELD_BTN_ICON_LABEL"
                    description="MOD_MOKO_HERO_FIELD_BTN_ICON_DESC"
                    default=""
                    hint="MOD_MOKO_HERO_FIELD_BTN_ICON_HINT"
                />

                <field
                    name="btn2_url"
                    type="url"
                    label="MOD_MOKO_HERO_FIELD_BTN2_URL_LABEL"
                    description="MOD_MOKO_HERO_FIELD_BTN_URL_DESC"
                    default=""
                    filter="url"
                />

                <field
                    name="btn2_style"
                    type="list"
                    label="MOD_MOKO_HERO_FIELD_BTN_STYLE_LABEL"
                    description="MOD_MOKO_HERO_FIELD_BTN_STYLE_DESC"
                    default="btn-outline-light"
                >
                    <option value="btn-primary">MOD_MOKO_HERO_BTN_STYLE_PRIMARY</option>
                    <option value="btn-secondary">MOD_MOKO_HERO_BTN_STYLE_SECONDARY</option>
                    <option value="btn-outline-primary">MOD_MOKO_HERO_BTN_STYLE_OUTLINE_PRIMARY</option>
                    <option value="btn-outline-light">MOD_MOKO_HERO_BTN_STYLE_OUTLINE_LIGHT</option>
                    <option value="btn-light">MOD_MOKO_HERO_BTN_STYLE_LIGHT</option>
                    <option value="btn-dark">MOD_MOKO_HERO_BTN_STYLE_DARK</option>
                </field>

                <!-- ── Button 3 ────────────────────────────────────────── -->

                <field
                    name="btn3_label"
                    type="text"
                    label="MOD_MOKO_HERO_FIELD_BTN3_LABEL_LABEL"
                    description="MOD_MOKO_HERO_FIELD_BTN_LABEL_DESC"
                    default=""
                />

                <field
                    name="btn3_icon"
                    type="text"
                    label="MOD_MOKO_HERO_FIELD_BTN_ICON_LABEL"
                    description="MOD_MOKO_HERO_FIELD_BTN_ICON_DESC"
                    default=""
                    hint="MOD_MOKO_HERO_FIELD_BTN_ICON_HINT"
                />

                <field
                    name="btn3_url"
                    type="url"
                    label="MOD_MOKO_HERO_FIELD_BTN3_URL_LABEL"
                    description="MOD_MOKO_HERO_FIELD_BTN_URL_DESC"
                    default=""
                    filter="url"
                />

                <field
                    name="btn3_style"
                    type="list"
                    label="MOD_MOKO_HERO_FIELD_BTN_STYLE_LABEL"
                    description="MOD_MOKO_HERO_FIELD_BTN_STYLE_DESC"
                    default="btn-secondary"
                >
                    <option value="btn-primary">MOD_MOKO_HERO_BTN_STYLE_PRIMARY</option>
                    <option value="btn-secondary">MOD_MOKO_HERO_BTN_STYLE_SECONDARY</option>
                    <option value="btn-outline-primary">MOD_MOKO_HERO_BTN_STYLE_OUTLINE_PRIMARY</option>
                    <option value="btn-outline-light">MOD_MOKO_HERO_BTN_STYLE_OUTLINE_LIGHT</option>
                    <option value="btn-light">MOD_MOKO_HERO_BTN_STYLE_LIGHT</option>
                    <option value="btn-dark">MOD_MOKO_HERO_BTN_STYLE_DARK</option>
                </field>

            </fieldset>

            <fieldset name="display" label="MOD_MOKO_HERO_FIELDSET_DISPLAY">

                <field
                    name="display_mode"
                    type="list"
                    label="MOD_MOKO_HERO_FIELD_DISPLAY_MODE_LABEL"
                    description="MOD_MOKO_HERO_FIELD_DISPLAY_MODE_DESC"
                    default="random"
                >
                    <option value="random">MOD_MOKO_HERO_DISPLAY_MODE_RANDOM</option>
                    <option value="slideshow">MOD_MOKO_HERO_DISPLAY_MODE_SLIDESHOW</option>
                </field>

                <field
                    name="slide_duration"
                    type="number"
                    label="MOD_MOKO_HERO_FIELD_SLIDE_DURATION_LABEL"
                    description="MOD_MOKO_HERO_FIELD_SLIDE_DURATION_DESC"
                    default="5"
                    min="2"
                    max="30"
                    step="1"
                    showon="display_mode:slideshow"
                />

                <field
                    name="slide_transition"
                    type="number"
                    label="MOD_MOKO_HERO_FIELD_SLIDE_TRANSITION_LABEL"
                    description="MOD_MOKO_HERO_FIELD_SLIDE_TRANSITION_DESC"
                    default="1"
                    min="0.5"
                    max="5"
                    step="0.5"
                    showon="display_mode:slideshow"
                />

                <field
                    name="height"
                    type="text"
                    label="MOD_MOKO_HERO_FIELD_HEIGHT_LABEL"
                    description="MOD_MOKO_HERO_FIELD_HEIGHT_DESC"
                    default="70vh"
                />

                <field
                    name="overlay_opacity"
                    type="range"
                    label="MOD_MOKO_HERO_FIELD_OVERLAY_LABEL"
                    description="MOD_MOKO_HERO_FIELD_OVERLAY_DESC"
                    min="0"
                    max="1"
                    step="0.05"
                    default="0.45"
                />

                <field
                    name="overlay_color"
                    type="color"
                    label="MOD_MOKO_HERO_FIELD_OVERLAY_COLOR_LABEL"
                    description="MOD_MOKO_HERO_FIELD_OVERLAY_COLOR_DESC"
                    default="#000000"
                />

                <field
                    name="content_align"
                    type="list"
                    label="MOD_MOKO_HERO_FIELD_ALIGN_LABEL"
                    description="MOD_MOKO_HERO_FIELD_ALIGN_DESC"
                    default="center"
                >
                    <option value="flex-start">JGLOBAL_LEFT</option>
                    <option value="center">JGLOBAL_CENTER</option>
                    <option value="flex-end">JGLOBAL_RIGHT</option>
                </field>

                <field
                    name="text_color"
                    type="color"
                    label="MOD_MOKO_HERO_FIELD_TEXT_COLOR_LABEL"
                    description="MOD_MOKO_HERO_FIELD_TEXT_COLOR_DESC"
                    default="#ffffff"
                />

                <field
                    name="bg_position"
                    type="list"
                    label="MOD_MOKO_HERO_FIELD_BG_POSITION_LABEL"
                    description="MOD_MOKO_HERO_FIELD_BG_POSITION_DESC"
                    default="center center"
                >
                    <option value="center center">MOD_MOKO_HERO_BG_CENTER</option>
                    <option value="center top">MOD_MOKO_HERO_BG_TOP</option>
                    <option value="center bottom">MOD_MOKO_HERO_BG_BOTTOM</option>
                </field>

            </fieldset>

        </fields>
    </config>
</extension>
